{
  "name": "linesync",
  "private": true,
  "workspaces": [
    "extension",
    "relay"
  ],
  "scripts": {
    "build": "npm run build:extension",
    "build:extension": "npm --prefix extension run compile",
    "package": "npm run package:extension",
    "package:extension": "npm --prefix extension run package",
    "relay:start": "npm --prefix relay run start",
    "relay:dev": "npm --prefix relay run dev",
    "relay:test:e2e": "npm --prefix relay run test:e2e",
    "start:relay": "npm run relay:start",
    "dev:relay": "npm run relay:dev"
  }
}
